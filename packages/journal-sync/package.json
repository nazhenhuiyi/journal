{
  "name": "@journal/sync",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./gitCore": {
      "types": "./src/gitCore.ts",
      "default": "./src/gitCore.ts"
    },
    "./lastWriteWins": {
      "types": "./src/lastWriteWins.ts",
      "default": "./src/lastWriteWins.ts"
    },
    "./smartMerge": {
      "types": "./src/smartMerge.ts",
      "default": "./src/smartMerge.ts"
    },
    "./scheduler": {
      "types": "./src/scheduler.ts",
      "default": "./src/scheduler.ts"
    },
    "./persistedSnapshot": {
      "types": "./src/persistedSnapshot.ts",
      "default": "./src/persistedSnapshot.ts"
    },
    "./statusPresentation": {
      "types": "./src/statusPresentation.ts",
      "default": "./src/statusPresentation.ts"
    },
    "./trace": {
      "types": "./src/trace.ts",
      "default": "./src/trace.ts"
    }
  },
  "dependencies": {
    "@journal/core": "workspace:*",
    "diff3": "0.0.3",
    "isomorphic-git": "^1.38.4"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "vitest": "^4.1.5"
  },
  "sideEffects": false
}
