{
  "name": "@journal/sync",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./gitCore": {
      "types": "./src/gitCore.ts",
      "default": "./src/gitCore.ts"
    },
    "./lastWriteWins": {
      "types": "./src/lastWriteWins.ts",
      "default": "./src/lastWriteWins.ts"
    },
    "./scheduler": {
      "types": "./src/scheduler.ts",
      "default": "./src/scheduler.ts"
    }
  },
  "dependencies": {
    "@journal/core": "file:../journal-core",
    "isomorphic-git": "^1.38.4"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "vitest": "^4.1.5"
  },
  "sideEffects": false
}
