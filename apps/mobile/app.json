{
  "expo": {
    "name": "且留",
    "slug": "journal-mobile",
    "description": "万物有迹，心事且留。",
    "scheme": "journal",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/brand/icon.png",
    "backgroundColor": "#F8F2E9",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "app.zilin.journal",
      "supportsTablet": true
    },
    "android": {
      "package": "app.zilin.journal",
      "softwareKeyboardLayoutMode": "resize",
      "versionCode": 13,
      "adaptiveIcon": {
        "foregroundImage": "./assets/brand/adaptive-icon.png",
        "backgroundColor": "#F8F2E9"
      }
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "cameraPermission": "允许且留使用相机，把拍下的照片保存到你的日记里。",
          "microphonePermission": false,
          "photosPermission": "允许且留选择照片，把它们保存到你的日记里。"
        }
      ],
      [
        "expo-media-library",
        {
          "granularPermissions": [
            "photo"
          ],
          "isAccessMediaLocationEnabled": true,
          "photosPermission": "允许且留读取所选照片的信息，用来保存照片拍摄地点。",
          "savePhotosPermission": false
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "允许且留使用当前位置，为碎碎念记录地点并获取今天的天气。"
        }
      ],
      [
        "expo-dev-client",
        {
          "launchMode": "launcher",
          "defaultLaunchURL": "http://127.0.0.1:8081",
          "ios": {
            "launchMode": "launcher",
            "defaultLaunchURL": "http://127.0.0.1:8081"
          },
          "android": {
            "launchMode": "launcher",
            "defaultLaunchURL": "http://127.0.0.1:8081"
          },
          "toolsButton": false,
          "skipOnboarding": true,
          "showMenuAtLaunch": false
        }
      ],
      "@maplibre/maplibre-react-native",
      "expo-secure-store",
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/Xiaolai.ttf"
          ]
        }
      ],
      "./plugins/withAndroidWorkManagerResolution",
      "./plugins/withAndroidArm64Only",
      "./plugins/withAndroidPredictiveBackOptOut",
      "./plugins/withAndroidDebugApplicationIdSuffix",
      [
        "expo-widgets",
        {
          "bundleIdentifier": "app.zilin.journal.widgets",
          "groupIdentifier": "group.app.zilin.journal",
          "frequentUpdates": true,
          "widgets": [
            {
              "name": "JournalMomentWidget",
              "displayName": "回看",
              "description": "每日回顾与周回顾。",
              "supportedFamilies": [
                "systemMedium"
              ]
            },
            {
              "name": "JournalMomentCompactWidget",
              "displayName": "此刻",
              "description": "根据此刻快速记录。",
              "supportedFamilies": [
                "systemSmall"
              ]
            }
          ]
        }
      ],
      "./plugins/withExpoWidgetsTargetVersion",
      [
        "react-native-android-widget",
        {
          "widgets": [
            {
              "name": "JournalMoment",
              "label": "回看",
              "description": "每日回顾与周回顾",
              "minWidth": "280dp",
              "minHeight": "110dp",
              "targetCellWidth": 4,
              "targetCellHeight": 2,
              "maxResizeWidth": "480dp",
              "maxResizeHeight": "140dp",
              "resizeMode": "horizontal",
              "updatePeriodMillis": 1800000
            },
            {
              "name": "JournalMomentCompact",
              "label": "此刻",
              "description": "根据此刻快速记录",
              "minWidth": "140dp",
              "minHeight": "70dp",
              "targetCellWidth": 2,
              "targetCellHeight": 1,
              "maxResizeWidth": "480dp",
              "maxResizeHeight": "140dp",
              "resizeMode": "horizontal|vertical",
              "updatePeriodMillis": 1800000
            }
          ]
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/brand/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#F8F2E9",
          "dark": {
            "backgroundColor": "#0c0a09"
          }
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "2574fbfa-faae-4559-9981-653a0b7a907f"
      }
    },
    "owner": "zilinr"
  }
}
