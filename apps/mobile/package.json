{
  "name": "@journal/mobile",
  "version": "0.0.0",
  "private": true,
  "main": "index.ts",
  "scripts": {
    "start": "node ./scripts/runExpo.mjs start",
    "android": "node ./scripts/runExpo.mjs start --android",
    "android:dev": "node ./scripts/runExpo.mjs run:android",
    "build:android:aab": "pnpm dlx eas-cli@20.1.0 build --platform android --profile production --local --non-interactive --output ./android/app/build/outputs/bundle/release/eas-production-local.aab",
    "build:android:aab:cloud": "pnpm dlx eas-cli@20.1.0 build --platform android --profile production",
    "build:android:apk": "pnpm dlx eas-cli@20.1.0 build --platform android --profile preview --local --non-interactive --output ./android/app/build/outputs/apk/release/eas-preview-local.apk",
    "build:android:apk:cloud": "pnpm dlx eas-cli@20.1.0 build --platform android --profile preview",
    "build:android:dev": "pnpm dlx eas-cli@20.1.0 build --platform android --profile development --local --non-interactive --output ./android/app/build/outputs/apk/development/eas-development-local.apk",
    "build:android:dev:cloud": "pnpm dlx eas-cli@20.1.0 build --platform android --profile development",
    "build:ios:dev": "pnpm dlx eas-cli@20.1.0 build --platform ios --profile development --local --non-interactive --output ./ios/build/eas-development-local.tar.gz",
    "build:ios:dev:cloud": "pnpm dlx eas-cli@20.1.0 build --platform ios --profile development",
    "e2e:android": "pnpm run e2e:android:artifact",
    "e2e:android:artifact": "JOURNAL_MOBILE_E2E_PLATFORM=android node ./scripts/runMaestroE2e.mjs",
    "e2e:android:dev": "JOURNAL_MOBILE_E2E_MODE=dev-client JOURNAL_MOBILE_E2E_PLATFORM=android node ./scripts/runMaestroE2e.mjs",
    "e2e:android:sync": "pnpm run e2e:android:artifact -- e2e/sync-now-flow.yaml",
    "e2e:android:sync-conflict": "pnpm run e2e:android:artifact -- e2e/sync-conflict-flow.yaml",
    "e2e:ios": "pnpm run e2e:ios:artifact",
    "e2e:ios:artifact": "JOURNAL_MOBILE_E2E_PLATFORM=ios node ./scripts/runMaestroE2e.mjs",
    "e2e:ios:dev": "JOURNAL_MOBILE_E2E_MODE=dev-client JOURNAL_MOBILE_E2E_PLATFORM=ios node ./scripts/runMaestroE2e.mjs",
    "e2e:ios:sync": "pnpm run e2e:ios:artifact -- e2e/sync-now-flow.yaml",
    "e2e:ios:sync-conflict": "pnpm run e2e:ios:artifact -- e2e/sync-conflict-flow.yaml",
    "eas:init": "pnpm dlx eas-cli@20.1.0 init",
    "eas:login": "pnpm dlx eas-cli@20.1.0 login",
    "install:android:apk": "adb install -r ./android/app/build/outputs/apk/release/eas-preview-local.apk",
    "ios": "node ./scripts/runExpo.mjs start --ios --localhost",
    "ios:dev": "node ./scripts/runExpo.mjs run:ios",
    "ios:launch": "node ./scripts/launchIosDevClient.mjs",
    "lint": "eslint src index.ts scripts --ext ts,tsx,mjs --report-unused-disable-directives --max-warnings 0",
    "logs:android:cat": "node ./scripts/pullAndroidLogs.mjs --cat",
    "logs:android:list": "node ./scripts/pullAndroidLogs.mjs --list",
    "logs:android:pull": "node ./scripts/pullAndroidLogs.mjs",
    "seed:photo-map-mock:ios": "node ./scripts/seedPhotoMapMockIos.mjs",
    "start:dev": "node ./scripts/runExpo.mjs start --dev-client",
    "web": "node ./scripts/runExpo.mjs start --web",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@expo/ui": "~56.0.17",
    "@expo/vector-icons": "15.0.3",
    "@journal/core": "workspace:*",
    "@journal/sync": "workspace:*",
    "@journal/theme": "workspace:*",
    "@maplibre/maplibre-react-native": "^11.3.4",
    "@react-navigation/native": "^7.2.6",
    "@react-navigation/native-stack": "^7.17.0",
    "buffer": "^6.0.3",
    "exifreader": "^4.41.0",
    "expo": "^56.0.11",
    "expo-asset": "~56.0.17",
    "expo-dev-client": "~56.0.20",
    "expo-file-system": "~56.0.8",
    "expo-font": "~56.0.6",
    "expo-image-manipulator": "~56.0.18",
    "expo-image-picker": "~56.0.17",
    "expo-linking": "~56.0.14",
    "expo-location": "~56.0.17",
    "expo-media-library": "~56.0.7",
    "expo-secure-store": "~56.0.4",
    "expo-splash-screen": "~56.0.10",
    "expo-widgets": "~56.0.18",
    "isomorphic-git": "^1.38.4",
    "nativewind": "^4.2.5",
    "react": "19.2.3",
    "react-native": "0.85.3",
    "react-native-android-widget": "^0.20.3",
    "react-native-css-interop": "^0.2.5",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-keyboard-controller": "1.21.6",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-worklets": "0.8.3"
  },
  "devDependencies": {
    "@types/geojson": "^7946.0.16",
    "babel-preset-expo": "~56.0.0",
    "prettier-plugin-tailwindcss": "^0.5.14",
    "tailwindcss": "^3.4.19",
    "typescript": "~6.0.3",
    "vitest": "^4.1.8"
  }
}
