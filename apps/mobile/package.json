{
  "name": "@journal/mobile",
  "version": "0.0.0",
  "private": true,
  "main": "index.ts",
  "scripts": {
    "start": "node ./scripts/runExpo.mjs start",
    "android": "node ./scripts/runExpo.mjs start --android",
    "android:dev": "node ./scripts/runExpo.mjs run:android",
    "build:android:aab": "npx --yes eas-cli@20.1.0 build --platform android --profile production",
    "build:android:apk": "npx --yes eas-cli@20.1.0 build --platform android --profile preview",
    "build:android:dev": "npx --yes eas-cli@20.1.0 build --platform android --profile development",
    "build:ios:dev": "npx --yes eas-cli@20.1.0 build --platform ios --profile development",
    "e2e": "node ./scripts/runMaestroE2e.mjs",
    "eas:init": "npx --yes eas-cli@20.1.0 init",
    "eas:login": "npx --yes eas-cli@20.1.0 login",
    "ios": "node ./scripts/runExpo.mjs start --ios --localhost",
    "ios:dev": "node ./scripts/runExpo.mjs run:ios",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "start:dev": "node ./scripts/runExpo.mjs start --dev-client",
    "web": "node ./scripts/runExpo.mjs start --web",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@expo/ui": "~56.0.17",
    "@expo/vector-icons": "15.0.3",
    "@journal/core": "file:../../packages/journal-core",
    "@journal/sync": "file:../../packages/journal-sync",
    "@journal/theme": "file:../../packages/journal-theme",
    "@react-navigation/native": "^7.2.6",
    "@react-navigation/native-stack": "^7.17.0",
    "buffer": "^6.0.3",
    "expo": "^56.0.11",
    "expo-dev-client": "~56.0.20",
    "expo-file-system": "~56.0.8",
    "expo-font": "~56.0.6",
    "expo-image-picker": "~56.0.17",
    "expo-linking": "~56.0.14",
    "expo-location": "~56.0.17",
    "expo-secure-store": "~56.0.4",
    "expo-splash-screen": "~56.0.10",
    "expo-widgets": "~56.0.18",
    "isomorphic-git": "^1.38.4",
    "nativewind": "^4.2.5",
    "react": "19.2.3",
    "react-native": "0.85.3",
    "react-native-android-widget": "^0.20.3",
    "react-native-css-interop": "^0.2.5",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4"
  },
  "devDependencies": {
    "babel-preset-expo": "~56.0.0",
    "prettier-plugin-tailwindcss": "^0.5.14",
    "tailwindcss": "^3.4.19",
    "typescript": "~6.0.3",
    "vitest": "^4.1.8"
  }
}
