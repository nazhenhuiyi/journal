{
  "name": "journal-workspace",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "overrides": {
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "scripts": {
    "dev": "npm run dev:desktop",
    "dev:desktop": "npm --workspace @journal/desktop run dev",
    "dev:mobile": "npm --workspace @journal/mobile run ios",
    "build": "npm run build:desktop",
    "build:desktop": "npm --workspace @journal/desktop run build",
    "build:mobile:android": "npm --workspace @journal/mobile run build:android:apk",
    "build:mobile:android:aab": "npm --workspace @journal/mobile run build:android:aab",
    "build:mobile:android:apk": "npm --workspace @journal/mobile run build:android:apk",
    "e2e": "npm run e2e:desktop:all && npm run e2e:sync:github",
    "e2e:desktop": "npm --workspace @journal/desktop exec vite build && playwright test e2e/desktop.spec.ts",
    "e2e:desktop:all": "npm --workspace @journal/desktop exec vite build && playwright test e2e/desktop.spec.ts e2e/desktop-sync.spec.ts",
    "e2e:desktop:sync": "npm --workspace @journal/desktop exec vite build && playwright test e2e/desktop-sync.spec.ts",
    "e2e:mobile": "npm --workspace @journal/mobile run e2e",
    "e2e:sync:github": "playwright test e2e/github-sync.spec.ts",
    "lint": "npm run lint:e2e && npm run lint:desktop && npm run lint:core && npm run lint:sync && npm run lint:theme && npm run lint:mobile",
    "lint:core": "npm --workspace @journal/core run lint",
    "lint:desktop": "npm --workspace @journal/desktop run lint",
    "lint:e2e": "eslint e2e playwright.config.ts --ext ts --report-unused-disable-directives --max-warnings 0",
    "lint:mobile": "npm --workspace @journal/mobile run lint",
    "lint:sync": "npm --workspace @journal/sync run lint",
    "lint:theme": "npm --workspace @journal/theme run lint",
    "preview": "npm --workspace @journal/desktop run preview",
    "test": "npm run test:unit && npm run test:integration",
    "test:core": "npm --workspace @journal/core run test",
    "test:desktop": "npm --workspace @journal/desktop run test",
    "test:desktop:integration": "npm --workspace @journal/desktop run test:integration",
    "test:integration": "npm run test:desktop:integration",
    "test:mobile": "npm --workspace @journal/mobile run test",
    "test:sync": "npm --workspace @journal/sync run test",
    "test:theme": "npm --workspace @journal/theme run test",
    "test:unit": "npm run test:desktop && npm run test:core && npm run test:sync && npm run test:theme && npm run test:mobile",
    "test:watch": "npm --workspace @journal/desktop run test:watch",
    "typecheck": "npm run typecheck:desktop && npm run typecheck:core && npm run typecheck:sync && npm run typecheck:theme && npm run typecheck:mobile",
    "typecheck:core": "npm --workspace @journal/core run typecheck",
    "typecheck:desktop": "npm --workspace @journal/desktop run typecheck",
    "typecheck:mobile": "npm --workspace @journal/mobile run typecheck",
    "typecheck:sync": "npm --workspace @journal/sync run typecheck",
    "typecheck:theme": "npm --workspace @journal/theme run typecheck"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "eslint": "^8.57.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.4.26"
  }
}
